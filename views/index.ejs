<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
     <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">
        <h3 class="text -3xl mb-5">Create Account</h3>
        <form action="/register" method="post">
            <input  class="px-3 py-2  rounded-md outline-none bg-transparent border-2 border-zinc-800 "type="text"name="name" placeholder="name">
            <input class="px-3 py-2  rounded-md outline-none bg-transparent border-2 border-zinc-800 " type="text" name="username" placeholder="username">
            <input class="px-3 py-2  rounded-md outline-none bg-transparent border-2 border-zinc-800 " type="email" name="email" placeholder="email">
            <input class="px-3 py-2  rounded-md outline-none bg-transparent border-2 border-zinc-800 " type="number" name="number" placeholder="number">
            <input class="px-3 py-2  rounded-md outline-none bg-transparent border-2 border-zinc-800 " type="password" name="passward" placeholder="passward">
            <input class="px-3 py-2 rounded-md bg-blue-500 " type="submit" value="Create Account">
        </form>
        
    </div>

</body>
</html>
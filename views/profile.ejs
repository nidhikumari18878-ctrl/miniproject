<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">
        <div class="flex justify-end w-full">
            <a href="/logout" class="bg-red-500 rounded-md px-3 py-2 text-sm mb-5 inline-block">Logout</a>
        </div>
        <div class="flex items-start gap-3">
            <div class="h-10 w-10  rounded-md overflow-hidden">
                <img class="w-full h-full object-cover" src="/uploads/<%=user.profilepic%>" alt="pic">
            </div>
        <h3 class="text -5xl "><span class="font=light">Hello,</span><%=user.name%>
        </h3>
        </div>
        <h5 class="mb-5 mt-3"> you can create new post.</h5>
        <form action="/post" method="post">
            <input class=" p-3 w-1/3 resize-none bg-transparent border-2 border-zinc-800 rounded-md" type="text"
                name="content" placeholder="what's on your mind ? ">
            <input type="submit" class="px-3 py-2 bg-blue-500 block rounded-md w-40 mt-2 text-sm cursor"
                value=" create new post">
        </form>
        <div class="posts mt-20">
            <h3 class="text-zinc-400"> Your Posts.</h3>
            <div class="postcontainer mt-5">

                <% if(user.posts && user.posts.length> 0){ %>

                    <% user.posts.slice().reverse().forEach(function(post){ %>

                        <div class="post w-1/3 p-4 mb-2 rounded-md border-2 border-zinc-700">
                            <h4 class="text-blue-500 mb-2">@<%= user.name%>
                            </h4>
                            <p class="text-sm tracking-tight">
                                <%= post.content %>
                            </p>

                             <small class="mt-2 inline-block"> <%=post.likes.length%>likes</small>
                            <div class="btnd flex gap-5 mt-5">
                                 <a href="/like/<%=post._id%>" class="text-blue-500">
                                <%=post.likes.indexOf(user._id)===-1 ?"like":"Unlike"%>
                                </a>
                                <a href="/edit/<%=post._id%>" class="text-zinc-500">Edit</a>
                            </div>
                         </div>
                        <% }) %>

                            <% } else { %>

                                <p>No posts yet</p>

                                <% } %>


                            
                    </div>
                </div>

            </div>
        </div>

        </form>
    </div>
<script> document.querySelector("img").addEventListener("click", function () { window.location.href = "/profile/upload"; }); </script>
</body>

</html>